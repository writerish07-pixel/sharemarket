# App
APP_NAME="Tata Motors CRM – Jaipur Dealership"
ENVIRONMENT=development
JWT_SECRET_KEY=change-this-to-a-secure-32-char-secret-key

# Database
POSTGRES_URL=postgresql+psycopg://crm:crm@db:5432/tata_crm

# Redis
REDIS_URL=redis://redis:6379/0

# File Storage
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_MB=20

# AWS S3 (optional)
USE_S3=false
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=ap-south-1

# WhatsApp Business API
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=

# SMS
SMS_API_KEY=
SMS_SENDER_ID=TMCRM

# Email (SendGrid)
SENDGRID_API_KEY=
FROM_EMAIL=crm@tatamotors-jaipur.in

# Dealership
DEALERSHIP_NAME="Tata Motors Authorized Dealership"
DEALERSHIP_CITY=Jaipur
DEALERSHIP_STATE=Rajasthan
DEALERSHIP_GST=08XXXXX1234X1ZX
DEALERSHIP_PHONE=+91-141-XXXXXXX
DEALERSHIP_ADDRESS="Plot No. XYZ, Tonk Road, Jaipur – 302015"
